# Copy this file to .env and fill in your Grafana Cloud OTLP credentials.
# .env is gitignored — never commit your token.
#
# Grab these values from your Grafana Cloud stack:
#   Connections → Add new connection → OpenTelemetry (OTLP) → Configure

OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <your-base64-encoded-instance-id:token>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
